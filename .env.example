# 招投标数据抓取与分析平台 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ==================== 智谱AI配置 ====================
# 智谱AI API Key (必填)
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# 智谱AI模型 (可选，默认: GLM-4-Flash-250414)
ZHIPU_MODEL=GLM-4-Flash-250414

# ==================== Flask配置 ====================
# Flask密钥 (生产环境必须修改)
FLASK_SECRET_KEY=your_secret_key_here

# ==================== 路径配置 ====================
# Excel文件路径 (可选，默认: 当前目录下的 1.xlsx)
# EXCEL_PATH=./1.xlsx

# SQLite数据库路径 (可选，默认: 当前目录下的 crawl_local.db)
# SQLITE_DB=./crawl_local.db

# ==================== 其他配置 ====================
# 日志级别 (可选: DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
